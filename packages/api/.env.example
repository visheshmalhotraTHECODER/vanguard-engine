PORT=8000
DATABASE_URL="postgresql://postgres:password@localhost:5432/vanguard?schema=public"
REDIS_URL="redis://localhost:6379"
JWT_SECRET="change-this-to-a-long-random-secret"
NODE_ENV="development"

# GitHub Webhook
# Generate a random secret: openssl rand -hex 32
# Then set the same secret in GitHub → Repo Settings → Webhooks
GITHUB_WEBHOOK_SECRET="your-webhook-secret-here"

# Your public ngrok URL (for local testing)
# e.g. https://abc123.ngrok.io → registered as webhook URL in GitHub
# NGROK_URL="https://your-ngrok-url.ngrok.io"
